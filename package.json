{
  "name": "@teelicht/pi-grepai",
  "version": "0.1.1",
  "description": "Pi extension package that bridges an installed grepai CLI into Pi slash commands and LLM tools",
  "author": "Thomas Lichtenecker",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teelicht/pi-grepai.git"
  },
  "homepage": "https://github.com/teelicht/pi-grepai#readme",
  "bugs": {
    "url": "https://github.com/teelicht/pi-grepai/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "grepai",
    "code-search",
    "cli"
  ],
  "files": [
    "src/",
    "docs/commands.md",
    "docs/configuration.md",
    "docs/releases.md",
    "docs/tools.md",
    "default-config.json",
    "config.example.json",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "npm test",
    "qa": "biome check --write && tsc --noEmit && npm run test:all",
    "lint": "biome check --write",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "node --experimental-strip-types --test test/unit/*.test.ts",
    "test:integration": "node --experimental-strip-types --test test/integration/*.test.ts",
    "test:all": "npm run test:unit && npm run test:integration"
  },
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^25.6.0",
    "typebox": "^1.1.24",
    "typescript": "^6.0.3"
  }
}
